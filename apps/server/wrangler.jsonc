{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kotoba-gym-server",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-25",
  "vars": {
    "GEMINI_MODEL": "gemini-3-flash-preview"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "kotoba-gym",
      "database_id": "local-kotoba-gym"
    }
  ],
  "observability": {
    "enabled": true
  }
}
